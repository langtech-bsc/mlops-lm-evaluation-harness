#!/bin/bash

#SBATCH --job-name="quanteval"
#SBATCH -D .
#SBATCH --output=/gpfs/projects/bsc88/mlops-lm-evaluation-harness/quanteval/logs/eval.%j.log
#SBATCH --partition=acc
#SBATCH --qos=acc_bscls
#SBATCH --account=bsc88
#SBATCH --nodes=1
#SBATCH --gres=gpu:2
#SBATCH --ntasks=2
#SBATCH --cpus-per-task=20
#SBATCH -t 1-00:00:00

# Log the Slurm options
grep SBATCH "$0" | head -n -1

# Redirect arguments to eval.sh
bash eval.sh $@
